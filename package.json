{
  "name": "hermes-chat",
  "displayName": "Hermes Agent Chat",
  "description": "Persistent multi-agent Hermes chat with streaming ACP tools, workspace context, per-agent settings, memory, and history",
  "version": "0.7.1",
  "publisher": "Poppywu124",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narizis/hermes-chat-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "keywords": [
    "hermes",
    "hermes-agent",
    "agent",
    "ai",
    "chat",
    "assistant",
    "memory",
    "acp",
    "mcp",
    "tool-calling",
    "streaming-chat",
    "coding-agent",
    "vscode-agent",
    "model-switching",
    "token-usage"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes-chat",
          "title": "Hermes Agent",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "hermes-chat": [
        {
          "type": "webview",
          "id": "hermes-chat.chatView",
          "name": "Chat",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "hermes-chat.newSession",
        "title": "Hermes: New Session",
        "icon": "$(add)"
      },
      {
        "command": "hermes-chat.openChatPanel",
        "title": "Hermes: Open Chat in Panel",
        "icon": "$(open-preview)"
      },
      {
        "command": "hermes-chat.clearChat",
        "title": "Hermes: Clear Chat Display"
      },
      {
        "command": "hermes-chat.runSetup",
        "title": "Hermes: Run Setup Wizard"
      },
      {
        "command": "hermes-chat.getApiKey",
        "title": "Hermes: Get API Key (Ace Data Cloud)"
      },
      {
        "command": "hermes-chat.refreshSettings",
        "title": "Refresh Hermes Settings",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes-chat.refreshMemory",
        "title": "Refresh Memory",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes-chat.refreshSkills",
        "title": "Refresh Skills",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes-chat.refreshCron",
        "title": "Refresh Cron Jobs",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes-chat.createCron",
        "title": "Hermes: Create Cron Job",
        "icon": "$(add)"
      },
      {
        "command": "hermes-chat.openCronJob",
        "title": "Hermes: Open Cron Job"
      },
      {
        "command": "hermes-chat.switchModel",
        "title": "Hermes: Switch Model",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "hermes-chat.refreshModel",
        "title": "Refresh Model",
        "icon": "$(refresh)"
      },
      {
        "command": "hermes-chat.selectModel",
        "title": "Hermes: Select Model"
      },
      {
        "command": "hermes-chat.refreshUsage",
        "title": "Refresh Usage",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Hermes Chat",
      "properties": {
        "hermes-chat.hermesPath": {
          "type": "string",
          "default": "hermes",
          "description": "Path to the Hermes CLI executable"
        },
        "hermes-chat.timeout": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Timeout in seconds for short Hermes ACP control requests (initialize, new session, set model). Does not apply to chat prompts — see streamIdleTimeout."
        },
        "hermes-chat.streamIdleTimeout": {
          "type": "number",
          "default": 120,
          "minimum": 5,
          "description": "Maximum seconds to wait between streaming chunks during a chat prompt before considering it stalled. Total prompt duration is unbounded as long as Hermes keeps streaming."
        },
        "hermes-chat.autoApproveTools": {
          "type": "boolean",
          "default": false,
          "description": "Automatically approve Hermes permission requests (running terminal commands, writing memory/skills, editing files) without prompting. Leave off to review each request. Enabling this bypasses the safety gate."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run compile && node test/smoke.js"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.1.1"
  }
}
